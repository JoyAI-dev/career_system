# Database
DATABASE_URL="postgresql://user:password@localhost:5432/student_system"

# Auth.js (v5 uses AUTH_SECRET and AUTH_URL)
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# ZhiPu OCR (student ID recognition)
ZHIPU_API_KEY="your-zhipu-api-key"

# Local file storage root (default: /var/lib/career_system in production, .data/ in dev)
# DATA_DIR="/var/lib/career_system"

# Admin Seed
ADMIN_SEED_PASSWORD="change-me-to-a-strong-password"
