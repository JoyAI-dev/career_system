generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(USER)
  name         String?
  school       String?
  major        String?
  grade        String?
  studentIdUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastActiveAt DateTime?

  responseSnapshots    ResponseSnapshot[]
  memberships          Membership[]
  createdActivities    Activity[]
  activityComments     ActivityComment[]
  recruitmentInfos     RecruitmentInfo[]
  responseComments     ResponseComment[]
  reflections          Reflection[]
  notifications        Notification[]
  auditLogs            AuditLog[]     @relation("auditLogs")
  announcementViews    AnnouncementView[]
  preference           UserPreference?
  communityMemberships CommunityMember[]
  ledGroups                  VirtualGroup[]        @relation("GroupLeader")
  virtualGroupMemberships    VirtualGroupMember[]
  pairingsAsUser1            Pairing[]             @relation("PairingUser1")
  pairingsAsUser2            Pairing[]             @relation("PairingUser2")
  pairingsCreated            Pairing[]             @relation("PairingCreatedBy")
  standbyEntry               StandbyUser?
  standbyAddedBy             StandbyUser[]         @relation("StandbyAddedBy")
  friendshipsRequested       Friendship[]          @relation("friendshipsRequested")
  friendshipsReceived        Friendship[]          @relation("friendshipsReceived")

  @@map("users")
}

model GradeOption {
  id       String  @id @default(cuid())
  label    String  @unique
  order    Int
  isActive Boolean @default(true)

  @@map("grade_options")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model LoginAttempt {
  username     String   @id
  count        Int      @default(0)
  firstAttempt DateTime @default(now())

  @@map("login_attempts")
}

// ─── Versioned Questionnaire System ─────────────────────────────────

enum TopicPreferenceMode {
  REPEAT    // Same questions repeated for each preference selection (e.g., cities)
  FILTER    // Unique SubTopics filtered by user's preference selections
  CONTEXT   // Single SubTopic, preference shown as contextual label
}

model QuestionnaireVersion {
  id        String   @id @default(cuid())
  version   Int      @unique
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  topics    Topic[]
  snapshots ResponseSnapshot[]

  @@map("questionnaire_versions")
}

model Topic {
  id                   String              @id @default(cuid())
  versionId            String
  name                 String
  order                Int
  preferenceMode       TopicPreferenceMode @default(CONTEXT)
  showInReport         Boolean             @default(true)
  preferenceCategoryId String?

  version            QuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  preferenceCategory PreferenceCategory?  @relation("TopicPreference", fields: [preferenceCategoryId], references: [id], onDelete: SetNull)
  subTopics          SubTopic[]

  @@index([versionId])
  @@map("topics")
}

model SubTopic {
  id                 String  @id @default(cuid())
  topicId            String
  name               String
  order              Int
  preferenceOptionId String?

  topic            Topic             @relation(fields: [topicId], references: [id], onDelete: Cascade)
  preferenceOption PreferenceOption? @relation(fields: [preferenceOptionId], references: [id], onDelete: SetNull)
  dimensions       Dimension[]

  @@index([topicId])
  @@index([preferenceOptionId])
  @@map("sub_topics")
}

model Dimension {
  id         String @id @default(cuid())
  subTopicId String
  name       String
  order      Int

  subTopic  SubTopic   @relation(fields: [subTopicId], references: [id], onDelete: Cascade)
  questions Question[]

  @@index([subTopicId])
  @@map("dimensions")
}

model Question {
  id          String @id @default(cuid())
  dimensionId String
  title       String
  order       Int

  dimension       Dimension        @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
  notes           QuestionNote[]
  answerOptions   AnswerOption[]
  responseAnswers ResponseAnswer[]
  reflections     Reflection[]

  @@map("questions")
}

model QuestionNote {
  id         String @id @default(cuid())
  questionId String
  label      String
  content    String

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_notes")
}

model AnswerOption {
  id         String @id @default(cuid())
  questionId String
  label      String
  score      Int
  order      Int

  question        Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  responseAnswers ResponseAnswer[]

  @@map("answer_options")
}

// ─── Response Snapshots (Immutable) ─────────────────────────────────

model ResponseSnapshot {
  id            String   @id @default(cuid())
  userId        String
  versionId     String
  completedAt   DateTime @default(now())
  context       String?
  activityId    String?
  isSnapshot    Boolean  @default(true)
  snapshotLabel String?

  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  version QuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  answers ResponseAnswer[]

  @@index([userId])
  @@map("response_snapshots")
}

model ResponseAnswer {
  id                 String  @id @default(cuid())
  snapshotId         String
  questionId         String
  selectedOptionId   String
  preferenceOptionId String?

  snapshot         ResponseSnapshot  @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  question         Question          @relation(fields: [questionId], references: [id])
  selectedOption   AnswerOption      @relation(fields: [selectedOptionId], references: [id])
  preferenceOption PreferenceOption? @relation("RepeatAnswers", fields: [preferenceOptionId], references: [id], onDelete: SetNull)
  comments         ResponseComment[]

  @@unique([snapshotId, questionId, preferenceOptionId])
  @@index([preferenceOptionId])
  @@map("response_answers")
}

model ResponseComment {
  id               String   @id @default(cuid())
  responseAnswerId String
  userId           String
  content          String
  activityTag      String?
  createdAt        DateTime @default(now())

  responseAnswer ResponseAnswer @relation(fields: [responseAnswerId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([responseAnswerId])
  @@map("response_comments")
}

model Reflection {
  id          String   @id @default(cuid())
  userId      String
  questionId  String
  content     String
  activityTag String?
  createdAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, userId])
  @@map("reflections")
}

// ─── Activity System ─────────────────────────────────────────────────

enum ActivityStatus {
  OPEN
  FULL
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum MemberRole {
  LEADER
  MEMBER
}

enum ActivityScope {
  GROUP_6      // Full group activity (6 people)
  PAIR_2       // Paired activity (2 people)
  CROSS_GROUP  // Cross-group competition (2 groups of 6)
  INDIVIDUAL   // Individual activity (1 person)
}

enum CompletionMode {
  LEADER_ONLY   // Only leader marks completion
  ALL_MEMBERS   // All members must mark completion
}

enum PairingMode {
  AUTO                          // System auto-pairs
  SELF_SELECT                   // Users choose their own partner
  SELF_SELECT_WITH_LEADER       // Users choose, leader can pair remaining
}

enum PairingStatus {
  PENDING     // Pairing request sent
  ACCEPTED    // Both parties confirmed
  DISSOLVED   // Leader dissolved the pairing
}

enum StandbyStatus {
  AVAILABLE   // Ready to be matched
  MATCHED     // Has been placed into a group
  INACTIVE    // Removed by admin
}

enum VirtualGroupStatus {
  FORMING     // Still gathering members
  ACTIVE      // All members present, activities ongoing
  COMPLETED   // All activities done
}

model ActivityType {
  id                 String  @id @default(cuid())
  name               String  @unique
  order              Int
  prerequisiteTypeId String?
  defaultCapacity    Int     @default(10)
  isEnabled          Boolean @default(true)
  scope              ActivityScope   @default(GROUP_6)
  peopleRequired     Int             @default(6)       // Actual people needed per activity instance
  duration           String?                            // Recommended duration e.g. "2小时"
  guideContent       String?         // Meeting guide content (markdown), stored as text
  intervalHours      Int             @default(24)       // Hours between this and previous activity
  completionMode     CompletionMode  @default(LEADER_ONLY)
  pairingMode        PairingMode?                       // null for non-paired activities
  allowViewLocked    Boolean         @default(true)     // Allow viewing content when locked
  timeoutHours       Int             @default(24)       // Standby timeout in hours

  prerequisiteType ActivityType?  @relation("TypePrerequisite", fields: [prerequisiteTypeId], references: [id])
  dependentTypes   ActivityType[] @relation("TypePrerequisite")
  activities       Activity[]
  pairings         Pairing[]

  @@map("activity_types")
}

model Tag {
  id   String @id @default(cuid())
  name String @unique

  activityTags ActivityTag[]

  @@map("tags")
}

model Activity {
  id                String         @id @default(cuid())
  typeId            String
  title             String
  capacity          Int
  guideMarkdown     String?
  status            ActivityStatus @default(OPEN)
  scheduledAt       DateTime?
  location          String?
  isOnline          Boolean        @default(false)
  createdBy         String
  createdAt         DateTime       @default(now())
  communityId          String?       // Denormalized from virtualGroup.communityId for query performance
  virtualGroupId       String?
  competitorActivityId String?       // For cross-group competition: the opposing team's activity
  winnerId             String?
  autoScheduledAt      DateTime?     // System auto-scheduled time

  type                ActivityType      @relation(fields: [typeId], references: [id])
  creator             User              @relation(fields: [createdBy], references: [id])
  community           Community?        @relation(fields: [communityId], references: [id])
  virtualGroup        VirtualGroup?     @relation(fields: [virtualGroupId], references: [id])
  competitorActivity  Activity?         @relation("CompetitionPair", fields: [competitorActivityId], references: [id], onDelete: SetNull)
  competedBy          Activity[]        @relation("CompetitionPair")
  winner              VirtualGroup?     @relation("CompetitionWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  activityTags        ActivityTag[]
  memberships         Membership[]
  activityComments    ActivityComment[]
  pairings            Pairing[]

  @@index([status])
  @@index([typeId])
  @@index([communityId])
  @@index([virtualGroupId])
  @@index([competitorActivityId])
  @@map("activities")
}

model ActivityTag {
  activityId String
  tagId      String

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([activityId, tagId])
  @@index([tagId])
  @@map("activity_tags")
}

model Membership {
  id          String     @id @default(cuid())
  activityId  String
  userId      String
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())
  completedAt DateTime?

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([userId])
  @@map("memberships")
}

model ActivityComment {
  id         String   @id @default(cuid())
  activityId String
  userId     String
  content    String
  createdAt  DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([activityId, createdAt])
  @@map("activity_comments")
}

// ─── Recruitment Info ───────────────────────────────────────────────

model RecruitmentInfo {
  id          String   @id @default(cuid())
  title       String
  company     String
  description String?
  eventDate   DateTime
  createdBy   String
  createdAt   DateTime @default(now())

  creator User @relation(fields: [createdBy], references: [id])

  @@index([eventDate])
  @@map("recruitment_info")
}

// ─── Notifications ──────────────────────────────────────────────────

enum NotificationType {
  ACTIVITY_FULL
  TIME_CONFIRMED
  NEW_COMMENT
  GROUP_FORMED        // Virtual group is complete
  PAIRING_REQUEST     // Someone wants to pair with you
  PAIRING_CONFIRMED   // Pairing accepted
  ACTIVITY_UNLOCKED   // Next activity is available
  ACTIVITY_SCHEDULED  // Auto-scheduled activity time set
  STANDBY_MATCHED     // Standby user matched to a group
  FRIEND_REQUEST      // Someone wants to be your friend
  FRIEND_ACCEPTED     // Friend request accepted
}

// ─── Friendship System ─────────────────────────────────────────────

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED    // After 3 rejections from same person
}

model Friendship {
  id              String           @id @default(cuid())
  requesterId     String
  addresseeId     String
  status          FriendshipStatus @default(PENDING)
  rejectionCount  Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  requester       User             @relation("friendshipsRequested", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee       User             @relation("friendshipsReceived", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@map("friendships")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ─── Announcements ─────────────────────────────────────────────────

model Announcement {
  id               String   @id @default(cuid())
  title            String
  content          String
  isActive         Boolean  @default(false)
  countdownSeconds Int      @default(20)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  views AnnouncementView[]

  @@map("announcements")
}

model AnnouncementView {
  id             String   @id @default(cuid())
  userId         String
  announcementId String
  viewedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId])
  @@index([userId])
  @@map("announcement_views")
}

// ─── Career Preference System ────────────────────────────────────────

enum PreferenceInputType {
  SINGLE_SELECT
  MULTI_SELECT
  HIERARCHICAL_MULTI
  SLIDER
}

model PreferenceCategory {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  icon        String?
  description String?
  order       Int
  inputType   PreferenceInputType
  isActive               Boolean             @default(true)
  isGroupingBasis        Boolean             @default(false)
  hierarchicalMatchLevel String?             // "PARENT" | "LEAF", only for HIERARCHICAL_MULTI

  topics        Topic[]            @relation("TopicPreference")
  options       PreferenceOption[]
  sliders       PreferenceSlider[]
  communityTags CommunityTag[]

  @@index([order])
  @@map("preference_categories")
}

model PreferenceOption {
  id             String  @id @default(cuid())
  categoryId     String
  label          String
  value          String
  order          Int
  isActive       Boolean @default(true)
  parentId       String?
  isAutoSelected Boolean @default(false)
  requiresChild  Boolean @default(false)

  category      PreferenceCategory        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  parent        PreferenceOption?          @relation("OptionHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children      PreferenceOption[]         @relation("OptionHierarchy")
  selections    UserPreferenceSelection[]
  subTopics     SubTopic[]
  repeatAnswers ResponseAnswer[]           @relation("RepeatAnswers")
  communityTags CommunityTag[]

  @@index([categoryId])
  @@index([parentId])
  @@map("preference_options")
}

model PreferenceSlider {
  id           String @id @default(cuid())
  categoryId   String
  label        String
  minValue     Int    @default(0)
  maxValue     Int    @default(10)
  defaultValue Int    @default(5)
  step         Int    @default(1)
  order        Int

  category PreferenceCategory          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  values   UserPreferenceSliderValue[]

  @@index([categoryId])
  @@map("preference_sliders")
}

model UserPreference {
  id          String   @id @default(cuid())
  userId      String   @unique
  completedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  selections   UserPreferenceSelection[]
  sliderValues UserPreferenceSliderValue[]

  @@map("user_preferences")
}

model UserPreferenceSelection {
  id               String @id @default(cuid())
  userPreferenceId String
  optionId         String

  userPreference UserPreference @relation(fields: [userPreferenceId], references: [id], onDelete: Cascade)
  option         PreferenceOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([userPreferenceId, optionId])
  @@index([optionId])
  @@map("user_preference_selections")
}

model UserPreferenceSliderValue {
  id               String @id @default(cuid())
  userPreferenceId String
  sliderId         String
  value            Int

  userPreference UserPreference @relation(fields: [userPreferenceId], references: [id], onDelete: Cascade)
  slider         PreferenceSlider @relation(fields: [sliderId], references: [id], onDelete: Cascade)

  @@unique([userPreferenceId, sliderId])
  @@map("user_preference_slider_values")
}

// ─── Community System ────────────────────────────────────────────────

model Community {
  id          String   @id @default(cuid())
  fingerprint String   @unique
  name        String
  memberCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tags           CommunityTag[]
  members        CommunityMember[]
  virtualGroups  VirtualGroup[]
  activities     Activity[]

  @@index([memberCount(sort: Desc)])
  @@map("communities")
}

model CommunityTag {
  id          String @id @default(cuid())
  communityId String
  categoryId  String
  optionId    String

  community Community          @relation(fields: [communityId], references: [id], onDelete: Cascade)
  category  PreferenceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  option    PreferenceOption   @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([communityId, categoryId])
  @@index([categoryId, optionId])
  @@map("community_tags")
}

model CommunityMember {
  id          String   @id @default(cuid())
  communityId String
  userId      String
  joinedAt    DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
  @@map("community_members")
}

// ─── Virtual Groups & Pairing ───────────────────────────────────────

model VirtualGroup {
  id            String              @id @default(cuid())
  communityId   String
  community     Community           @relation(fields: [communityId], references: [id], onDelete: Restrict)
  name          String?
  status        VirtualGroupStatus  @default(FORMING)
  leaderId      String?
  leader        User?               @relation("GroupLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now())

  members           VirtualGroupMember[]
  activities        Activity[]
  pairings          Pairing[]
  wonCompetitions   Activity[]      @relation("CompetitionWinner")

  @@index([communityId])
  @@map("virtual_groups")
}

// INVARIANT: A user can only be in one VirtualGroup per Community — enforced in application layer
model VirtualGroupMember {
  id              String        @id @default(cuid())
  virtualGroupId  String
  virtualGroup    VirtualGroup  @relation(fields: [virtualGroupId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt        DateTime      @default(now())
  order           Int           // Join sequence number (informational; actual leader set via VirtualGroup.leaderId)

  @@unique([virtualGroupId, userId])
  @@index([userId])
  @@map("virtual_group_members")
}

// INVARIANT: user1Id < user2Id (lexicographic ordering) — enforced in application layer to prevent duplicate pairings
model Pairing {
  id              String        @id @default(cuid())
  virtualGroupId  String
  virtualGroup    VirtualGroup  @relation(fields: [virtualGroupId], references: [id], onDelete: Cascade)
  activityTypeId  String
  activityType    ActivityType  @relation(fields: [activityTypeId], references: [id], onDelete: Restrict)
  activityId      String?       // Linked activity once created
  activity        Activity?     @relation(fields: [activityId], references: [id], onDelete: SetNull)
  user1Id         String
  user1           User          @relation("PairingUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id         String
  user2           User          @relation("PairingUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  status          PairingStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  createdById     String        // Who initiated the pairing
  createdBy       User          @relation("PairingCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([virtualGroupId, activityTypeId, user1Id, user2Id])
  @@index([virtualGroupId, activityTypeId])
  @@map("pairings")
}

// ─── Standby & Scheduling ──────────────────────────────────────────

model StandbyUser {
  id           String        @id @default(cuid())
  userId       String        @unique   // One standby entry per user
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       StandbyStatus @default(AVAILABLE)
  addedById    String?
  addedBy      User?         @relation("StandbyAddedBy", fields: [addedById], references: [id], onDelete: SetNull)
  note         String?       // Admin note
  createdAt    DateTime      @default(now())
  matchedAt    DateTime?     // When matched to a group

  @@index([status])
  @@map("standby_users")
}

model SchedulingConfig {
  id                      String   @id @default("default")
  morningCutoff           String   @default("10:00")  // Before this = morning rule
  eveningCutoff           String   @default("17:00")  // After this = evening rule
  morningDelayHours       Int      @default(0)        // Hours delay if filled before morning cutoff
  eveningDelayHours       Int      @default(24)       // Hours delay if filled after evening cutoff
  defaultActivityTime     String   @default("09:00")  // Default scheduled time
  suggestedMorningStart   String   @default("09:00")
  suggestedMorningEnd     String   @default("11:00")
  suggestedAfternoonStart String   @default("14:00")
  suggestedAfternoonEnd   String   @default("16:00")
  updatedAt               DateTime @updatedAt

  @@map("scheduling_configs")
}

// ─── Audit Log ──────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetId   String
  details    String
  createdAt  DateTime @default(now())

  admin User @relation("auditLogs", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetId])
  @@map("audit_logs")
}
