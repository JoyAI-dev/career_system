generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(USER)
  name         String?
  school       String?
  major        String?
  grade        String?
  studentIdUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  responseSnapshots  ResponseSnapshot[]
  memberships        Membership[]
  createdActivities  Activity[]
  activityComments   ActivityComment[]
  recruitmentInfos   RecruitmentInfo[]
  responseComments   ResponseComment[]
  reflections        Reflection[]
  notifications      Notification[]
  auditLogs          AuditLog[]     @relation("auditLogs")

  @@map("users")
}

model GradeOption {
  id       String  @id @default(cuid())
  label    String  @unique
  order    Int
  isActive Boolean @default(true)

  @@map("grade_options")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model LoginAttempt {
  username     String   @id
  count        Int      @default(0)
  firstAttempt DateTime @default(now())

  @@map("login_attempts")
}

// ─── Versioned Questionnaire System ─────────────────────────────────

model QuestionnaireVersion {
  id        String   @id @default(cuid())
  version   Int      @unique
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  topics    Topic[]
  snapshots ResponseSnapshot[]

  @@map("questionnaire_versions")
}

model Topic {
  id        String @id @default(cuid())
  versionId String
  name      String
  order     Int

  version    QuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  dimensions Dimension[]

  @@index([versionId])
  @@map("topics")
}

model Dimension {
  id      String @id @default(cuid())
  topicId String
  name    String
  order   Int

  topic     Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questions Question[]

  @@map("dimensions")
}

model Question {
  id          String @id @default(cuid())
  dimensionId String
  title       String
  order       Int

  dimension       Dimension        @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
  notes           QuestionNote[]
  answerOptions   AnswerOption[]
  responseAnswers ResponseAnswer[]
  reflections     Reflection[]

  @@map("questions")
}

model QuestionNote {
  id         String @id @default(cuid())
  questionId String
  label      String
  content    String

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_notes")
}

model AnswerOption {
  id         String @id @default(cuid())
  questionId String
  label      String
  score      Int
  order      Int

  question        Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  responseAnswers ResponseAnswer[]

  @@map("answer_options")
}

// ─── Response Snapshots (Immutable) ─────────────────────────────────

model ResponseSnapshot {
  id            String   @id @default(cuid())
  userId        String
  versionId     String
  completedAt   DateTime @default(now())
  context       String?
  activityId    String?
  isSnapshot    Boolean  @default(true)
  snapshotLabel String?

  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  version QuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  answers ResponseAnswer[]

  @@index([userId])
  @@map("response_snapshots")
}

model ResponseAnswer {
  id               String @id @default(cuid())
  snapshotId       String
  questionId       String
  selectedOptionId String

  snapshot       ResponseSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  question       Question         @relation(fields: [questionId], references: [id])
  selectedOption AnswerOption     @relation(fields: [selectedOptionId], references: [id])
  comments       ResponseComment[]

  @@map("response_answers")
}

model ResponseComment {
  id               String   @id @default(cuid())
  responseAnswerId String
  userId           String
  content          String
  activityTag      String?
  createdAt        DateTime @default(now())

  responseAnswer ResponseAnswer @relation(fields: [responseAnswerId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([responseAnswerId])
  @@map("response_comments")
}

model Reflection {
  id          String   @id @default(cuid())
  userId      String
  questionId  String
  content     String
  activityTag String?
  createdAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, userId])
  @@map("reflections")
}

// ─── Activity System ─────────────────────────────────────────────────

enum ActivityStatus {
  OPEN
  FULL
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum MemberRole {
  LEADER
  MEMBER
}

model ActivityType {
  id                 String  @id @default(cuid())
  name               String  @unique
  order              Int
  prerequisiteTypeId String?
  defaultCapacity    Int     @default(10)
  isEnabled          Boolean @default(true)

  prerequisiteType ActivityType?  @relation("TypePrerequisite", fields: [prerequisiteTypeId], references: [id])
  dependentTypes   ActivityType[] @relation("TypePrerequisite")
  activities       Activity[]

  @@map("activity_types")
}

model Tag {
  id   String @id @default(cuid())
  name String @unique

  activityTags ActivityTag[]

  @@map("tags")
}

model Activity {
  id            String         @id @default(cuid())
  typeId        String
  title         String
  capacity      Int
  guideMarkdown String?
  status        ActivityStatus @default(OPEN)
  scheduledAt   DateTime?
  location      String?
  isOnline      Boolean        @default(false)
  createdBy     String
  createdAt     DateTime       @default(now())

  type             ActivityType      @relation(fields: [typeId], references: [id])
  creator          User              @relation(fields: [createdBy], references: [id])
  activityTags     ActivityTag[]
  memberships      Membership[]
  activityComments ActivityComment[]

  @@index([status])
  @@index([typeId])
  @@map("activities")
}

model ActivityTag {
  activityId String
  tagId      String

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([activityId, tagId])
  @@index([tagId])
  @@map("activity_tags")
}

model Membership {
  id          String     @id @default(cuid())
  activityId  String
  userId      String
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())
  completedAt DateTime?

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@index([userId])
  @@map("memberships")
}

model ActivityComment {
  id         String   @id @default(cuid())
  activityId String
  userId     String
  content    String
  createdAt  DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([activityId, createdAt])
  @@map("activity_comments")
}

// ─── Recruitment Info ───────────────────────────────────────────────

model RecruitmentInfo {
  id          String   @id @default(cuid())
  title       String
  company     String
  description String?
  eventDate   DateTime
  createdBy   String
  createdAt   DateTime @default(now())

  creator User @relation(fields: [createdBy], references: [id])

  @@index([eventDate])
  @@map("recruitment_info")
}

// ─── Notifications ──────────────────────────────────────────────────

enum NotificationType {
  ACTIVITY_FULL
  TIME_CONFIRMED
  NEW_COMMENT
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ─── Audit Log ──────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetId   String
  details    String
  createdAt  DateTime @default(now())

  admin User @relation("auditLogs", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetId])
  @@map("audit_logs")
}
